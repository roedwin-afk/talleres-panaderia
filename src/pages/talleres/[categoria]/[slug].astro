---
// src/pages/talleres/[categoria]/[slug].astro
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ZohoFormularioHTML from "../../../components/ZohoFormularioHTML.astro";
import { categorias } from "../../../data/categorias";

export async function getStaticPaths() {
  const talleres = await getCollection("talleres");
  return talleres.map((taller) => ({
    params: { categoria: taller.data.categoria, slug: taller.id },
    props: { taller },
  }));
}

const { taller } = Astro.props;
const { Content } = await render(taller);
const base = import.meta.env.BASE_URL;

const categoriaInfo = categorias.find((c) => c.id === taller.data.categoria);

const {
  nombre,
  fecha,
  horarioInicio,
  horarioFin,
  instructor,
  instructorGenero,
  nivel,
  cuposDisponibles,
  cuposTotales,
  precio,
  imagen,
  imagenAlt,
  categoria,
} = taller.data;

const etiquetaInstructor =
  instructorGenero === "f" ? "Instructora" : "Instructor";
const fechaFormateada = fecha.toLocaleDateString("es-SV", {
  weekday: "long",
  day: "numeric",
  month: "long",
});
const precioFormateado = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
}).format(precio);
---

<Layout
  title={`${nombre} | Talleres | Equipo y Partes El Salvador`}
  description={`Taller de ${nombre}, impartido por ${instructor}. ${cuposDisponibles} cupos disponibles.`}
>
  <div
    class="categoria-scope"
    style={categoriaInfo
      ? `--brand-primary: ${categoriaInfo.colorAcento}; --brand-primary-hover: color-mix(in srgb, ${categoriaInfo.colorAcento} 80%, black);`
      : ""}
  >
    <article class="detalle-taller">
      <div class="container">
        <a href={`${base}talleres/${categoria}/`} class="volver"
          >&larr; Volver a {categoriaInfo?.nombre ?? "Talleres"}</a
        >

        <div class="detalle-header">
          <img src={imagen} alt={imagenAlt} class="detalle-imagen" />
          <div>
            <span class="badge badge-nivel">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
              >
                <line x1="4" y1="20" x2="4" y2="14"></line>
                <line x1="12" y1="20" x2="12" y2="9"></line>
                <line x1="20" y1="20" x2="20" y2="4"></line>
              </svg>
              {nivel}
            </span>
            <h1>{nombre}</h1>
            <p class="detalle-instructor">{etiquetaInstructor}: {instructor}</p>
            <ul class="detalle-datos">
              <li><span>Fecha:</span> <span>{fechaFormateada}</span></li>
              <li>
                <span>Horario:</span>
                <span>{horarioInicio} - {horarioFin}</span>
              </li>
              <li>
                <span>Cupos:</span>
                <span class="detalle-cupos">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                  </svg>
                  {cuposDisponibles} de {cuposTotales}
                </span>
                +
              </li>
              <li>
                <span>Precio:</span>
                <span class="detalle-precio">{precioFormateado}</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="detalle-contenido">
          <Content />
        </div>
      </div>
    </article>

    <ZohoFormularioHTML tallerPreseleccionado={taller} />
  </div>
</Layout>

<style>
  .detalle-taller {
    padding: var(--space-lg) 0;
  }
  .volver {
    display: inline-block;
    margin-bottom: var(--space-md);
    color: var(--text-muted);
  }

  .detalle-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
    margin-bottom: var(--space-lg);
  }

  .detalle-imagen {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .detalle-instructor {
    color: var(--text-muted);
    margin: var(--space-xs) 0 var(--space-sm);
  }

  .detalle-datos {
    list-style: none;
  }

  .detalle-cupos {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
  }

  .detalle-datos li {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-light);
  }

  .detalle-precio {
    font-weight: 700;
    color: var(--brand-primary);
  }
  .detalle-contenido {
    max-width: 700px;
    margin: 0 auto var(--space-lg);
  }

  .detalle-contenido :global(h2) {
    color: var(--brand-primary);
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }
  .detalle-contenido :global(ul) {
    padding-left: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .detalle-header {
      grid-template-columns: 1fr;
    }
  }
</style>
