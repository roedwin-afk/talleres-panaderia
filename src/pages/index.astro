---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ListadoTalleres from '../components/ListadoTalleres.astro';
import TalleresAnteriores from '../components/TalleresAnteriores.astro';
import Testimonios from '../components/Testimonios.astro';
import FAQ from '../components/FAQ.astro';
import FormularioInscripcion from '../components/FormularioInscripcion.astro';
import { sitio } from '../data/content';

const talleres = await getCollection('talleres');
---

<Layout
  title="Talleres de Panadería | Equipo y Partes El Salvador"
  description="Talleres prácticos de alta panadería con equipo profesional. Cupos limitados, inscríbete hoy."
>
  <Hero
    titulo={sitio.hero.titulo}
    descripcion={sitio.hero.descripcion}
    textoBoton={sitio.hero.textoBoton}
    anclaBoton={sitio.hero.anclaBoton}
    imagenFondo={sitio.hero.imagenFondo}
  />
  <ListadoTalleres />
  <TalleresAnteriores />
  <Testimonios />
  <FAQ />
  <FormularioInscripcion talleres={talleres} />
</Layout>