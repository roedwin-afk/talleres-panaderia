---
// src/pages/index.astro — hub principal
import Layout from '../layouts/Layout.astro';
import TarjetaCategoria from '../components/TarjetaCategoria.astro';
import { categorias } from '../data/categorias';
---

<Layout
  title="Talleres Profesionales | Equipo y Partes El Salvador"
  description="Talleres prácticos con equipo profesional: panadería, pastelería, carnicería y cocina. Elegí tu categoría e inscribite hoy."
>
  <section class="hub-hero">
    <div class="container">
      <h1>Domina Nuevas Técnicas con Equipamiento Profesional</h1>
      <p>
        Elegí la categoría de taller que más se ajusta a tu negocio o pasión. Grupos reducidos,
        instructores expertos y uso práctico de equipo industrial real.
      </p>
    </div>
  </section>

  <section class="hub-categorias">
    <div class="container">
      <div class="grid">
        {categorias.map((categoria) => (
          <TarjetaCategoria categoria={categoria} />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hub-hero {
    background-color: var(--text-main);
    color: var(--text-light);
    padding: var(--space-xl) 0 var(--space-lg);
    text-align: center;
  }

  .hub-hero h1 {
    color: var(--text-light);
    font-size: 2.8rem;
    max-width: 800px;
    margin: 0 auto var(--space-sm);
  }

  .hub-hero p {
    color: #E2E8F0;
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
  }

  .hub-categorias {
    padding: var(--space-lg) 0;
  }

  @media (max-width: 768px) {
    .hub-hero h1 { font-size: 2rem; }
  }
</style>