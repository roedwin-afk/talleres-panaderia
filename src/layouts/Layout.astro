---
// src/layouts/Layout.astro
import '../styles/talleres-tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { sitio } from '../data/content';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Talleres prácticos de panadería con equipo y maquinaria profesional. Cupos limitados.',
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header
      nombreEmpresa={sitio.nombreEmpresa}
      textoBotonNav={sitio.header.textoBotonNav}
      anclaBotonNav={sitio.header.anclaBotonNav}
    />
    <slot />
    <Footer copyright={sitio.footer.copyright} />
  </body>
</html>