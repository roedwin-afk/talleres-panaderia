---
// src/components/talleres/FormularioInscripcion.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  // Para el formulario general (index): recibe todos los talleres para el <select>
  talleres?: CollectionEntry<'talleres'>[];
  // Para la página de detalle: el taller ya viene fijo, sin <select>
  tallerPreseleccionado?: CollectionEntry<'talleres'>;
}

const { talleres, tallerPreseleccionado } = Astro.props;
---

<section id="registration" class="registration-section">
  <div class="container">
    <div class="form-container">
      <h3>Reserva tu espacio</h3>
      <p class="form-desc">
        Llena este formulario sin compromiso para separar tu cupo. Un asesor se comunicará contigo para confirmar los detalles y finalizar la inscripción.
      </p>

      <form id="form-preinscripcion">
        <div class="form-group">
          <label for="name" class="form-label">Nombre Completo</label>
          <input type="text" id="name" name="nombre" class="form-control" placeholder="Ej. Juan Pérez" required />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input type="email" id="email" name="correo" class="form-control" placeholder="ejemplo@correo.com" required />
        </div>

        <div class="form-group">
          <label for="phone" class="form-label">Teléfono / WhatsApp</label>
          <input type="tel" id="phone" name="telefono" class="form-control" placeholder="Ej. 7000-0000" required />
        </div>

        {tallerPreseleccionado ? (
          <div class="form-group">
            <span class="form-label">Taller de Interés</span>
            <div class="form-control form-control-static">{tallerPreseleccionado.data.nombre}</div>
            <input type="hidden" name="taller" value={tallerPreseleccionado.id} />
          </div>
        ) : (
          <div class="form-group">
            <label for="workshop-select" class="form-label">Taller de Interés</label>
            <select id="workshop-select" name="taller" class="form-control" required>
              <option value="" disabled selected>Selecciona un taller...</option>
              {talleres?.map((taller) => (
                <option value={taller.id}>
                  {taller.data.nombre} — {taller.data.fecha.toLocaleDateString('es-SV', { day: 'numeric', month: 'short' })}
                </option>
              ))}
            </select>
          </div>
        )}

        <button type="submit" class="btn btn-primary btn-block" style="margin-top: 1rem;">
          Solicitar Pre-inscripción
        </button>
        <p class="form-note">
          *El pago y confirmación final se gestionan de forma directa con nuestro equipo comercial.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .registration-section {
    background-color: var(--bg-surface-alt);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--border-light);
  }

  .form-container {
    background-color: var(--bg-surface);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    /* max-width: 600px; */
    margin: 0 auto;
  }

  .form-container h3 {
    margin-bottom: var(--space-xs);
    text-align: center;
    font-size: 1.8rem;
  }

  .form-desc {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
    font-size: 0.95rem;
  }

  .form-group {
    margin-bottom: var(--space-sm);
  }

  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .form-control {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-family: var(--font-family-body);
    font-size: 1rem;
    transition: border-color var(--transition-speed);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--brand-primary);
    box-shadow: 0 0 0 3px rgba(192, 86, 33, 0.1);
  }

  .form-control-static {
    background-color: var(--bg-surface-alt);
    font-weight: 600;
    color: var(--text-main);
  }

  .form-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
  }
</style>

<script>
  // Envío mock por ahora — se conecta a Power Automate + Zoho Sheet más adelante.
  const form = document.getElementById('form-preinscripcion') as HTMLFormElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Gracias por tu preinscripción. Un asesor se comunicará contigo pronto.');
    form.reset();
  });

  // Pre-selección vía query param (?taller=slug), usado desde TarjetaTaller
  // cuando el formulario general (con <select>) está en la misma página.
  const params = new URLSearchParams(window.location.search);
  const tallerParam = params.get('taller');
  const select = document.getElementById('workshop-select') as HTMLSelectElement | null;
  if (tallerParam && select) {
    select.value = tallerParam;
  }
</script>