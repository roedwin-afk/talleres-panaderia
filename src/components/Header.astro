---
import { Image } from "astro:assets";
import logo from "../assets/editable-logo-equipoypartes.webp";
// import logo from '../assets/logo-alargado.png';
import { categorias } from "../data/categorias";
import { contenidoPorCategoria } from "../data/content";

interface Props {
  nombreEmpresa: string;
}

const { nombreEmpresa } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header>
  <div class="container header-content">
    <a href={base} class="logo">
      <Image
        src={logo}
        alt={nombreEmpresa}
        width={200}
        height={184}
        class="navbar__logo-img"
      />
      <!-- <Image src={logo} alt={nombreEmpresa} width={400} height={110} class="navbar__logo-img" /> -->
    </a>

    <button
      id="nav-toggle"
      class="nav-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="main-nav" class="main-nav">
      <ul>
        {
          categorias.map((cat) => {
            const disponible = !!contenidoPorCategoria[cat.id];
            const href = `${base}talleres/${cat.id}/`;
            const activo = Astro.url.pathname.startsWith(href);
            return (
              <li>
                {disponible ? (
                  <a href={href} class:list={["nav-link", { activo }]}>
                    {cat.nombre}
                  </a>
                ) : (
                  <span class="nav-link nav-link--disabled">
                    {cat.nombre} <small>(Próximamente)</small>
                  </span>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    background-color: var(--bg-surface);
    padding: var(--space-sm) 0;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-xs);
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .navbar__logo-img {
    display: block;
    height: 7rem;
    width: auto;
  }

  .main-nav ul {
    display: flex;
    list-style: none;
    gap: var(--space-md);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nav-link {
    color: var(--text-main);
    text-decoration: none;
    font-weight: 600;
    padding: 0.4rem 0;
    border-bottom: 2px solid transparent;
    transition:
      border-color var(--transition-speed),
      color var(--transition-speed);
  }

  .nav-link:hover {
    color: var(--brand-primary);
  }

  .nav-link.activo {
    color: var(--brand-primary);
    border-bottom-color: var(--brand-primary);
  }

  .nav-link--disabled {
    color: var(--text-muted);
    cursor: default;
  }

  .nav-link--disabled small {
    font-size: 0.75em;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background-color: var(--text-main);
  }

  @media (max-width: 768px) {
    .main-nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
      padding: var(--space-sm) 0;
    }
  }
</style>

<script is:inline>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("main-nav");
  toggle?.addEventListener("click", () => {
    const isOpen = nav.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>
