---
// src/components/talleres/Header.astro
interface Props {
  nombreEmpresa: string;
  textoBotonNav: string;
  anclaBotonNav: string;
}

const { nombreEmpresa, textoBotonNav, anclaBotonNav } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header>
  <div class="container header-content">
    <a href={base} class="logo">
      <!-- <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
      </svg> -->
      {nombreEmpresa}
    </a>
    <nav>
      <a href={anclaBotonNav} class="btn btn-outline" style="padding: 0.5rem 1rem;">{textoBotonNav}</a>
    </nav>
  </div>
</header>

<style>
  header {
    background-color: var(--bg-surface);
    padding: var(--space-sm) 0;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-family-headings);
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    gap: 10px;
  }
</style>