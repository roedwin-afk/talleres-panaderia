---
import type { Categoria } from "../data/categorias";
import { contenidoPorCategoria } from "../data/content";

interface Props {
    categoria: Categoria;
}

const { categoria } = Astro.props;
const base = import.meta.env.BASE_URL;
const disponible = !!contenidoPorCategoria[categoria.id];
---

<a
    href={`${base}talleres/${categoria.id}/`}
    class="tarjeta-categoria"
    style={`--color-cat: ${categoria.colorAcento}`}
>
    <div class="tarjeta-img-wrap">
        <img src={categoria.imagen} alt={categoria.nombre} />
        {!disponible && <span class="badge-proximamente">Próximamente</span>}
    </div>
    <div class="tarjeta-body">
        <h3>{categoria.nombre}</h3>
        <p>{categoria.descripcionCorta}</p>
    </div>
</a>

<style>
    .tarjeta-categoria {
        display: block;
        background-color: var(--bg-surface);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        text-decoration: none;
        color: inherit;
        transition:
            transform var(--transition-speed),
            box-shadow var(--transition-speed);
        border-top: 4px solid var(--color-cat);
    }

    .tarjeta-categoria:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
    }

    .tarjeta-img-wrap {
        position: relative;
        height: 180px;
    }

    .tarjeta-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .badge-proximamente {
        position: absolute;
        top: var(--space-xs);
        right: var(--space-xs);
        background-color: var(--text-main);
        color: var(--text-light);
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .tarjeta-body {
        padding: var(--space-md);
    }

    .tarjeta-body h3 {
        color: var(--color-cat);
        margin-bottom: var(--space-xs);
        font-size: 1.4rem;
    }

    .tarjeta-body p {
        color: var(--text-muted);
        font-size: 0.95rem;
    }
</style>
