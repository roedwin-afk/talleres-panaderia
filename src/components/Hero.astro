---
// src/components/talleres/Hero.astro
interface Props {
  titulo: string;
  descripcion: string;
  textoBoton: string;
  anclaBoton: string;
  imagenesFondo: string[];
}
const { titulo, descripcion, textoBoton, anclaBoton, imagenesFondo } =
  Astro.props;
---

<section class="hero">
  {
    imagenesFondo.map((img, i) => (
      <div
        class="hero-bg-slide"
        class:list={{ activa: i === 0 }}
        style={`background-image: url('${img}')`}
      />
    ))
  }
  <div class="container hero-content">
    <h1>{titulo}</h1>
    <p>{descripcion}</p>
    <!-- <a href={anclaBoton} class="btn btn-primary">{textoBoton}</a> -->
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--text-main);
    color: var(--text-light);
    padding: var(--space-xl) 0;
    overflow: hidden;
    text-align: center;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.8));
    z-index: 1;
  }

  .hero-bg-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    z-index: 0;
  }

  .hero-bg-slide.activa {
    opacity: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    color: var(--text-light);
    font-size: 3rem;
    margin-bottom: var(--space-sm);
  }

  .hero p {
    font-size: 1.25rem;
    margin-bottom: var(--space-md);
    color: #e2e8f0;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.2rem;
    }
  }
</style>
<script is:inline>
  document.querySelectorAll('.hero').forEach((hero) => {
    const slides = hero.querySelectorAll('.hero-bg-slide');
    if (slides.length <= 1) return; // nada que rotar con 1 sola imagen

    let actual = 0;
    setInterval(() => {
      slides[actual].classList.remove('activa');
      actual = (actual + 1) % slides.length;
      slides[actual].classList.add('activa');
    }, 5000); // cambia cada 5 segundos
  });
</script>