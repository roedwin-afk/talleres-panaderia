---
// src/components/talleres/Hero.astro
interface Props {
  titulo: string;
  descripcion: string;
  textoBoton: string;
  anclaBoton: string;
  imagenFondo: string;
}

const { titulo, descripcion, textoBoton, anclaBoton, imagenFondo } = Astro.props;
---

<section class="hero" style={`--hero-bg-image: url('${imagenFondo}')`}>
  <div class="container hero-content">
    <h1>{titulo}</h1>
    <p>{descripcion}</p>
    <a href={anclaBoton} class="btn btn-primary">{textoBoton}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--text-main);
    color: var(--text-light);
    padding: var(--space-xl) 0;
    overflow: hidden;
    text-align: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.8)),
                var(--hero-bg-image) center/cover;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    color: var(--text-light);
    font-size: 3rem;
    margin-bottom: var(--space-sm);
  }

  .hero p {
    font-size: 1.25rem;
    margin-bottom: var(--space-md);
    color: #E2E8F0;
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2.2rem; }
  }
</style>