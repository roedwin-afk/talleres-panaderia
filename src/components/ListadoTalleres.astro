---
// src/components/talleres/ListadoTalleres.astro
import { getCollection } from "astro:content";
import TarjetaTaller from "./TarjetaTaller.astro";

interface Props {
  categoria: string;
}

const { categoria } = Astro.props;

const talleresEntries = await getCollection(
  "talleres",
  ({ data }) => data.categoria === categoria,
);

const talleresOrdenados = talleresEntries.sort(
  (a, b) => a.data.fecha.valueOf() - b.data.fecha.valueOf(),
);
---

<section id="workshops" class="workshops-section">
  <div class="container">
    <div class="section-header">
      <h2>Cartelera de Talleres</h2>
      <p>
        Grupos reducidos para garantizar atención personalizada y uso práctico
        de todos nuestros equipos en exhibición.
      </p>
    </div>

    <div class="grid">
      {talleresOrdenados.map((taller) => <TarjetaTaller taller={taller} />)}
    </div>
  </div>
</section>

<style>
  .workshops-section {
    padding: var(--space-lg) 0;
  }
</style>
