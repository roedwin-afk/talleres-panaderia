---
// src/components/ZohoFormularioHTML.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  talleres?: CollectionEntry<'talleres'>[];
  tallerPreseleccionado?: CollectionEntry<'talleres'>;
}

const { talleres, tallerPreseleccionado } = Astro.props;
---

<section id="registration" class="registration-section">
  <div class="container">
    <div class="form-container">
      <h3>Reserva tu espacio</h3>
      <p class="form-desc">
        Llena este formulario sin compromiso para separar tu cupo. Un asesor se comunicará contigo para confirmar los detalles y finalizar la inscripción.
      </p>

      <!-- Change or deletion of the name attributes in the input tags will lead to empty values on record submission -->
      <form
        action="https://forms.zohopublic.com/promaica/form/RegistrodeTalleresdePanadera/formperma/8Znatko58Yl6p6O17r3YomF3yP2d-ifDUGoJ42r0lTo/htmlRecords/submit"
        name="form"
        id="zoho-form"
        method="POST"
        accept-charset="UTF-8"
        enctype="multipart/form-data"
      >
        <input type="hidden" name="zf_referrer_name" value="" />
        <input type="hidden" name="zf_redirect_url" value="" />
        <input type="hidden" name="zc_gad" value="" />

        <div class="form-row">
          <div class="form-group">
            <label for="Name_First" class="form-label">Nombres <em>*</em></label>
            <input type="text" id="Name_First" name="Name_First" maxlength="255" class="form-control" required />
          </div>
          <div class="form-group">
            <label for="Name_Last" class="form-label">Apellidos</label>
            <input type="text" id="Name_Last" name="Name_Last" maxlength="255" class="form-control" />
          </div>
        </div>

        <div class="form-group">
          <label for="Email" class="form-label">Correo Electrónico</label>
          <input type="email" id="Email" name="Email" maxlength="255" class="form-control" placeholder="ejemplo@correo.com" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="phone-code" class="form-label">Código <em>*</em></label>
            <input
              type="text"
              id="phone-code"
              name="PhoneNumber_countrycode"
              maxlength="20"
              class="form-control"
              value="503"
              required
            />
          </div>
          <div class="form-group">
            <label for="phone-number" class="form-label">Número <em>*</em></label>
            <input
              type="text"
              id="phone-number"
              name="PhoneNumber_countrycodeval"
              maxlength="10"
              class="form-control"
              placeholder="Ej. 7000-0000"
              required
            />
          </div>
        </div>

        {tallerPreseleccionado ? (
          <div class="form-group">
            <span class="form-label">Taller de Interés</span>
            <div class="form-control form-control-static">{tallerPreseleccionado.data.nombre}</div>
            <input type="hidden" name="Dropdown" value={tallerPreseleccionado.data.nombre} />
          </div>
        ) : (
          <div class="form-group">
            <label for="Dropdown" class="form-label">Taller de Interés <em>*</em></label>
            <select id="Dropdown" name="Dropdown" class="form-control" required>
              <option value="" disabled selected>Selecciona un taller...</option>
              {talleres?.map((taller) => (
                <option value={taller.data.nombre}>{taller.data.nombre}</option>
              ))}
            </select>
          </div>
        )}

        <div class="form-group">
          <label for="MultiLine" class="form-label">Mensaje o comentario (opcional)</label>
          <textarea id="MultiLine" name="MultiLine" maxlength="65535" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-block" style="margin-top: 1rem;">
          Solicitar Pre-inscripción
        </button>
        <p class="form-note">
          *El pago y confirmación final se gestionan de forma directa con nuestro equipo comercial.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .registration-section {
    background-color: var(--bg-surface-alt);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--border-light);
  }

  .form-container {
    background-color: var(--bg-surface);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .form-container h3 {
    margin-bottom: var(--space-xs);
    text-align: center;
    font-size: 1.8rem;
  }

  .form-desc {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
    font-size: 0.95rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .form-group {
    margin-bottom: var(--space-sm);
  }

  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .form-label em {
    color: var(--status-few);
    font-style: normal;
  }

  .form-control {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-family: var(--font-family-body);
    font-size: 1rem;
    transition: border-color var(--transition-speed);
  }

  .form-control:focus {
    outline: none;
    border-color: var(--brand-primary);
    box-shadow: 0 0 0 3px rgba(192, 86, 33, 0.1);
  }

  .form-control-static {
    background-color: var(--bg-surface-alt);
    font-weight: 600;
    color: var(--text-main);
  }

  .form-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
  }

  @media (max-width: 600px) {
    .form-container { padding: var(--space-md) var(--space-sm); }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  // Pre-selección vía query param (?taller=id), busca el <option> cuyo texto
  // visible coincide con el nombre del taller (Zoho usa el nombre completo como value).
  document.addEventListener('DOMContentLoaded', function () {
    var params = new URLSearchParams(window.location.search);
    var tallerParam = params.get('taller');
    var select = document.getElementById('Dropdown');
    if (tallerParam && select && select.tagName === 'SELECT') {
      for (var i = 0; i < select.options.length; i++) {
        if (select.options[i].value.toLowerCase().indexOf(tallerParam.toLowerCase()) !== -1) {
          select.value = select.options[i].value;
          break;
        }
      }
    }
    // Referrer para tracking, reemplaza el zf_referrer_name vacío del hidden input
    var referrerInput = document.querySelector('input[name="zf_referrer_name"]');
    if (referrerInput) referrerInput.value = window.location.href;
  });
</script>