---
// src/components/talleres/Footer.astro
interface Props {
  copyrightBase: string;
}

const { copyrightBase } = Astro.props;
const anioActual = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p>© {anioActual} {copyrightBase}</p>
  </div>
</footer>

<style>
  footer {
    background-color: var(--text-main);
    color: var(--text-light);
    padding: var(--space-md) 0;
    text-align: center;
  }

  footer p {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>