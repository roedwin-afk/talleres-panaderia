---
import type { TallerAnterior } from "../data/content";
interface Props {
  items: TallerAnterior[];
}
const { items } = Astro.props;
---

<section class="galeria-section">
  <div class="container">
    <div class="section-header">
      <h2>Talleres Anteriores</h2>
      <p>
        Un vistazo a nuestras sesiones pasadas y el ambiente práctico de cada
        taller.
      </p>
    </div>

    <div class="grid galeria-grid">
      {
        items.map((item) => (
          <figure class="galeria-item">
            <img src={item.imagen} alt={item.titulo} />
            <figcaption>{item.titulo}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .galeria-section {
    padding: var(--space-lg) 0;
  }

  .galeria-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .galeria-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .galeria-item img {
    height: 220px;
    flex-shrink: 0;
    object-fit: cover;
  }

  .galeria-item figcaption {
    padding: var(--space-sm);
    background-color: var(--bg-surface);
    font-weight: 600;
    font-size: 0.95rem;
    text-align: center;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
