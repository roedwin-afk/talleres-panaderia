---
// src/components/talleres/TarjetaTaller.astro
import type { CollectionEntry } from "astro:content";

interface Props {
    taller: CollectionEntry<"talleres">;
}

const { taller } = Astro.props;
const {
    nombre,
    categoria,
    fecha,
    horarioInicio,
    horarioFin,
    instructor,
    instructorGenero,
    nivel,
    cuposDisponibles,
    precio,
    imagen,
    imagenAlt,
} = taller.data;

// Umbral de "pocos cupos": <= 5, coincide con el criterio del mockup original
// (3 cupos = "pocos", 8 y 12 = "disponibles"). Ajustable si Marketing define otro criterio.
const pocosCupos = cuposDisponibles <= 5;

const fechaFormateada = fecha.toLocaleDateString("es-SV", {
    weekday: "short",
    day: "numeric",
    month: "long",
});

const precioFormateado = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
}).format(precio);

const etiquetaInstructor =
    instructorGenero === "f" ? "Instructora" : "Instructor";

const base = import.meta.env.BASE_URL;
---

<article class="card">
    <div class="card-img-placeholder">
        <img src={imagen} alt={imagenAlt} />
    </div>
    <div class="card-content">
        <div class="card-meta">
            <span class="badge badge-nivel">
                 <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                >
                     <line x1="4" y1="20" x2="4" y2="14"></line>
                     <line x1="12" y1="20" x2="12" y2="9"></line>
                     <line x1="20" y1="20" x2="20" y2="4"></line>
                    
                </svg>
                 {nivel}
                
            </span>
            {
                pocosCupos ? (
                    <span class="badge few">
         <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
           <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
           <circle cx="9" cy="7" r="4" />
           <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
         </svg>
         ¡Solo {cuposDisponibles}!
       </span>
                ) : (
                    <span class="badge available">
         <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
           <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
           <circle cx="9" cy="7" r="4" />
           <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
           <path d="M16 3.13a4 4 0 0 1 0 7.75" />
         </svg>
         {cuposDisponibles} disponibles
       </span>
                )
            }
        </div>

        <h3 class="card-title">{nombre}</h3>

        <div class="card-instructor">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
            {etiquetaInstructor}: {instructor}
        </div>

        <ul class="card-details-list">
            <li><span>Fecha:</span> <span>{fechaFormateada}</span></li>
            <li>
                <span>Horario:</span>
                <span>{horarioInicio} - {horarioFin}</span>
            </li>
        </ul>

        <div class="card-price">{precioFormateado}</div>

        <div class="card-actions">
            <a
                href={`${base}talleres/${categoria}/${taller.id}`}
                class="btn btn-outline">Ver detalles</a
            >
            <a
                href={`/${base}#registration?taller=${taller.id}`}
                class="btn btn-primary">Inscribirme</a
            >
        </div>
    </div>
</article>

<style>
    .card {
        background-color: var(--bg-surface);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        transition:
            transform var(--transition-speed),
            box-shadow var(--transition-speed);
        display: flex;
        flex-direction: column;
        border: 1px solid var(--border-light);
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
    }

    .card-img-placeholder {
        height: 200px;
        background-color: var(--bg-surface-alt);
    }

    .card-img-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-content {
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-xs);
    }

    .card-title {
        font-size: 1.5rem;
        margin-bottom: var(--space-xs);
    }

    .card-instructor {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: var(--space-sm);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .card-details-list {
        list-style: none;
        margin-bottom: var(--space-md);
        padding-top: var(--space-sm);
        border-top: 1px solid var(--border-light);
    }

    .card-details-list li {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .card-details-list li span:first-child {
        color: var(--text-muted);
    }

    .card-details-list li span:last-child {
        font-weight: 600;
        text-align: right;
    }

    .card-price {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--brand-primary);
        text-align: right;
        margin-bottom: var(--space-sm);
    }

    .card-actions {
        margin-top: auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-xs);
    }

    @media (max-width: 768px) {
        .card-actions {
            grid-template-columns: 1fr;
        }
    }
</style>
